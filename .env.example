# Токен телеграм-бота, выданный @BotFather
BOT_TOKEN=

# Единственный источник данных — imb_backend.
API_BASE_URL=http://localhost:4000
SERVICE_TOKEN=replace-with-the-same-value-as-backend-participant-token

# Локальный Mini App. Для настоящего Telegram Web App нужен публичный HTTPS URL.
MINI_APP_PORT=3000
MINI_APP_HOST=0.0.0.0
MINI_APP_URL=
WEBHOOK_BASE_URL=
WEBHOOK_SECRET=generate-a-long-random-secret
