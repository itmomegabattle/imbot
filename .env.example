# Токен телеграм-бота, выданный @BotFather
BOT_TOKEN=

# tg id администратора. Если пусто/0, первый пользователь станет организатором
ADMIN_TG_ID=

# Production: all canonical data comes from imb_backend.
BACKEND_MODE=remote
API_BASE_URL=http://localhost:4000
SERVICE_TOKEN=replace-with-the-same-value-as-backend-participant-token

# Локальный Mini App. Для настоящего Telegram Web App нужен публичный HTTPS URL.
MINI_APP_PORT=3000
MINI_APP_HOST=0.0.0.0
MINI_APP_URL=

# Путь к локальному хранению состояния бота
DATA_DIR=./data
