{
  "name": "@itmomegabattle/imbot",
  "version": "1.0.0",
  "description": "ITMO Megabattle participant Telegram bot and pixel Mini App",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p .",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run build"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "dotenv": "^16.4.5",
    "grammy": "^1.30.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  }
}
